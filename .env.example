# ==== Django ====
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==== Postgres ====
POSTGRES_DB=aitpoludsky
POSTGRES_USER=aitpoludsky
POSTGRES_PASSWORD=aitpoludsky_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ==== Frontend ====
VITE_API_BASE_URL=/api
# Where Vite dev-server proxies /api to. Inside docker-compose use http://backend:8000.
# When running Vite locally without docker — use http://localhost:8000.
VITE_API_PROXY_TARGET=http://backend:8000
